# PulseBoard environment variables
# Copy this file to .env.local and fill in real values. NEVER commit .env.local.

# ---- NextAuth ----
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-me-with-a-32-byte-random-string
NEXTAUTH_URL=http://localhost:3000

# ---- Google OAuth ----
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Gemini ----
# Get a key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ---- Database ----
# For local dev, SQLite is easiest. For production use Postgres.
DATABASE_URL="file:./dev.db"

# ---- Token encryption ----
# Generate with: openssl rand -base64 32
# Used to encrypt Google refresh tokens at rest.
TOKEN_ENCRYPTION_KEY=replace-me-with-a-32-byte-random-string
